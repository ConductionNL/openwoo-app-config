{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeberg.org/Conduction/openwoo-app-config/schema/openregister-config.schema.json",
  "title": "OpenRegister configuration export",
  "description": "Envelope contract for an OpenRegister configuration export. Structural only; semantic and anti-pollution checks live in scripts/oac.py.",
  "type": "object",
  "required": ["openapi", "info", "components"],
  "properties": {
    "openapi": { "type": "string" },
    "info": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "x-openregister": { "type": "object" },
    "components": {
      "type": "object",
      "description": "Config buckets. Each is a map of slug->entity or a list of entities.",
      "properties": {
        "registers": { "type": ["object", "array"] },
        "schemas": { "type": ["object", "array"] },
        "mappings": { "type": ["object", "array"] },
        "sources": { "type": ["object", "array"] },
        "rules": { "type": ["object", "array"] },
        "synchronizations": { "type": ["object", "array"] },
        "endpoints": { "type": ["object", "array"] },
        "jobs": { "type": ["object", "array"] },
        "workflows": { "type": ["object", "array"] },
        "objects": { "type": ["object", "array"] }
      },
      "additionalProperties": true
    }
  }
}
